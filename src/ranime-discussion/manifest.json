{
  "id": "ranime-discussion",
  "name": "r/anime Discussion",
  "version": "1.1.1",
  "manifestURI": "https://raw.githubusercontent.com/Kaktusmann/seanime-extension/refs/heads/main/src/ranime-discussion/manifest.json",
  "language": "typescript",
  "type": "plugin",
  "description": "Adds a button to the anime page that searches for the discussion thread on r/anime for the last seen anime episode.",
  "author": "Kaktus",
  "icon": "https://raw.githubusercontent.com/Kaktusmann/seanime-extension/refs/heads/main/src/ranime-discussion/icon.ico",
  "website": "",
  "lang": "multi",
  "payloadURI": "https://raw.githubusercontent.com/Kaktusmann/seanime-extension/refs/heads/main/src/ranime-discussion/main.ts",
  "plugin": {
    "version": "1",
    "permissions": {
      "scopes": [],
      "allow": {
        "unsafeFlags": [
          {
            "flag": "dom-script-manipulation",
            "reason": "Needed to open external URLs from episode context menu items."
          }
        ]
      }
    }
  },
  "isDevelopment": false
}